Checks: "-*,\
modernize-use-auto"
WarningsAsErrors: '*'
HeaderFilterRegex: '^${RELATIVE_SOURCE_DIR}(include|src|test)/'
UseColor: true
CheckOptions:
  - key:             modernize-use-auto.MinTypeNameLength
    value:           '0'
  - key:             modernize-use-auto.RemoveStars
    value:           'true'
